{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "exports": {
    "./models": {
      "import": "./src/models/index.ts"
    }
  },
  "scripts": {
    "dev": "nodemon",
    "build": "npx tsc",
    "start": "npm run build && npm run start:node",
    "start:node": "node dist/index.js",
    "start:app": "cross-env STATIC=../app/dist npm run start",
    "start:proto": "cross-env STATIC=../proto/dist npm run start",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "express",
    "backend"
  ],
  "author": "kubiak@calpoly.edu",
  "license": "BSD-3-Clause",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "geojson": "^0.5.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "proto": "^1.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/geojson": "^7946.0.16",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.2"
  }
}
